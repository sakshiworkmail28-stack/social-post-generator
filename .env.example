# ── Required ─────────────────────────────────────────────────────────────────
# Anthropic — get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Image generation (enables "Image Post" feature) ───────────────────────────
# Free read-only token from https://huggingface.co/settings/tokens
# Without this, image posts are disabled and a message is shown in the UI.
HF_TOKEN=hf_your_token_here

# ── Email delivery (enables sending results to user's email) ──────────────────
# Free API key from https://resend.com → API Keys → Create API Key
# Without this, posts are still generated but not emailed.
RESEND_API_KEY=re_your_key_here

# Sender address — must be a verified domain in your Resend account.
# Comment out (or delete) to use the Resend test sender onboarding@resend.dev,
# which can only deliver to your own Resend account email address.
# RESEND_FROM=Social Post Generator <you@yourdomain.com>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
