# ── Required ─────────────────────────────────────────────────────────────────
# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Image generation — OpenAI DALL-E 3 ───────────────────────────────────────
# https://platform.openai.com/api-keys
# Without this, image posts are disabled and a message is shown in the UI.
OPENAI_API_KEY=sk-your-openai-key-here

# ── Email delivery — Resend ───────────────────────────────────────────────────
# https://resend.com → API Keys → Create API Key
# Without this, posts are still generated but not emailed.
RESEND_API_KEY=re_your_key_here

# Sender address — must be a verified domain in your Resend account.
# Comment out to use onboarding@resend.dev (delivers only to your Resend account email).
# RESEND_FROM=Social Post Generator <you@yourdomain.com>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
